{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2020",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node16",
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "newLine": "LF",
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": [
      "ES2020"
    ],
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "include": ["src/**/*.ts"]
}
